{
  "name": "tourney-helper",
  "version": "1.0.0",
  "description": "Tournament management tool with start.gg integration",
  "main": "src/backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "svelte-kit dev",
    "dev:backend": "nodemon src/backend/server.js",
    "build": "svelte-kit build",
    "start": "node src/backend/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "node-fetch": "^2.7.0",
    "svelte": "^4.2.0"
  },
  "devDependencies": {
    "@sveltejs/kit": "^1.25.0",
    "@types/node": "^20.6.0",
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1",
    "typescript": "^5.2.2"
  }
}
